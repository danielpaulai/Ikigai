# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Models — chat uses a faster/cheaper default; generate uses Sonnet for JSON quality.
# Set explicitly if defaults change — see https://docs.anthropic.com/en/docs/about-claude/models
# Default in code is Sonnet for both (quality). Use Haiku for chat only if cost forces it.
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-5
ANTHROPIC_MODEL_GENERATE=claude-sonnet-4-5

# Rate limits (per IP, per minute, in-memory per instance). Set RATE_LIMIT_ENABLED=false to disable.
# Behind NAT many users share one IP — raise limits or use Redis-based limiting for production scale.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MINUTE=90
RATE_LIMIT_GENERATE_PER_MINUTE=15

# Optional: global rate limits across all server instances (Upstash Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Supabase — public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (never expose to client; never commit real values)
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket name (create in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET=ikigai-reports
